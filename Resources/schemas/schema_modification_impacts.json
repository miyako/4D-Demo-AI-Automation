{
  "type": "object",
  "required": [
    "eventID",
    "confidenceScore",
    "modificationSummary",
    "impacts",
    "totalExtraCost",
    "requiresAvenant",
    "deadlineForValidation",
    "draftAvenantMessage",
    "candidateEvents",
    "executionActions"
  ],
  "additionalProperties": false,
  "properties": {
    "eventID": {
      "type": "string",
      "description": "ID 4D de l'événement concerné."
    },
    "confidenceScore": {
      "type": "number",
      "description": "Niveau de confiance dans l'identification de l'événement (0 à 1)."
    },
    "modificationSummary": {
      "type": "string",
      "description": "Résumé lisible des modifications demandées."
    },
    "impacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "impactType",
          "label",
          "costDelta",
          "impactStatus",
          "serviceID",
          "serviceLabel",
          "quantityChange",
          "requiresClientValidation",
          "note"
        ],
        "additionalProperties": false,
        "properties": {
          "impactType": {
            "type": "string",
            "enum": [
              "add_service",
              "remove_service",
              "update_quantity",
              "update_price",
              "date_change",
              "venue_change",
              "guest_count_change",
              "catering_change",
              "av_change",
              "other"
            ]
          },
          "label": {
            "type": "string",
            "description": "Description courte de l'impact."
          },
          "costDelta": {
            "type": "number",
            "description": "Impact financier en euros (positif = surcoût, négatif = économie)."
          },
          "impactStatus": {
            "type": "string",
            "enum": [
              "confirmed",
              "pending",
              "to_confirm"
            ]
          },
          "serviceID": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "ID du service en base de données (si applicable)."
          },
          "serviceLabel": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Libellé du service catalogue correspondant."
          },
          "quantityChange": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Variation de quantité."
          },
          "requiresClientValidation": {
            "type": "boolean",
            "description": "True si cette ligne nécessite une validation explicite du client."
          },
          "note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Note ou avertissement associé à cet impact."
          }
        }
      }
    },
    "totalExtraCost": {
      "type": "number",
      "description": "Somme totale de tous les impacts financiers."
    },
    "requiresAvenant": {
      "type": "boolean",
      "description": "True si les modifications impliquent un avenant contractuel."
    },
    "deadlineForValidation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Date limite YYYY-MM-DD pour que le client valide l'avenant, ou null."
    },
    "draftAvenantMessage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Brouillon de message pour envoyer l'avenant au client, ou null."
    },
    "candidateEvents": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "eventID",
              "eventDate",
              "venueName",
              "guestCount",
              "contractRef",
              "confidenceScore"
            ],
            "additionalProperties": false,
            "properties": {
              "eventID": {
                "type": "string"
              },
              "eventDate": {
                "type": "string",
                "description": "Format YYYY-MM-DD."
              },
              "venueName": {
                "type": "string"
              },
              "guestCount": {
                "type": "integer"
              },
              "contractRef": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "confidenceScore": {
                "type": "number"
              }
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "description": "Présent seulement en cas d'ambiguïté – liste des événements candidats, ou null."
    },
    "executionActions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "actionType",
          "label",
          "priority",
          "icon",
          "hiddenPrompt"
        ],
        "additionalProperties": false,
        "properties": {
          "actionType": {
            "type": "string",
            "enum": [
              "calculate_impact"
            ]
          },
          "label": {
            "type": "string",
            "description": "Libellé court du bouton d'action."
          },
          "priority": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "icon": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Emoji ou nom d'icône."
          },
          "hiddenPrompt": {
            "type": "string",
            "description": "Describes exactly what service changes to apply: which services to REMOVE (use exact label from existing services) and which services to SEARCH and ADD (only if available in standard event catalog)."
          }
        }
      },
      "description": "Actions exécutables proposées à l'utilisateur."
    }
  }
}