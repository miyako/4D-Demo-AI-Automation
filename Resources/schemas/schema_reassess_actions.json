{
  "type": "object",
  "required": ["actions"],
  "additionalProperties": false,
  "properties": {
    "actions": {
      "type": "array",
      "description": "Remaining actions that are still relevant after the last change. Remove any action that is no longer needed.",
      "items": {
        "type": "object",
        "required": [
          "actionType",
          "label",
          "priority",
          "description",
          "deadlineToDecide",
          "estimatedExtraCost",
          "suggestedServices",
          "hiddenPrompt"
        ],
        "additionalProperties": false,
        "properties": {
          "actionType": {
            "type": "string",
            "enum": ["add_services", "replace_services", "switch_venue", "notify_client"]
          },
          "label": { "type": "string" },
          "description": {
            "anyOf": [{ "type": "string" }, { "type": "null" }]
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "deadlineToDecide": {
            "anyOf": [{ "type": "string" }, { "type": "null" }]
          },
          "estimatedExtraCost": {
            "anyOf": [{ "type": "number" }, { "type": "null" }]
          },
          "suggestedServices": {
            "anyOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "null" }
            ]
          },
          "hiddenPrompt": { "type": "string" }
        }
      }
    }
  }
}
