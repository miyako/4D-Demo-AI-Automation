{
  "type": "object",
  "required": [
    "eventID",
    "riskLevel",
    "forecastDate",
    "weatherSummary",
    "explanation",
    "actions",
    "weatherData",
    "affectedServices",
    "draftClientMessage"
  ],
  "additionalProperties": false,
  "properties": {
    "eventID": {
      "type": "string",
      "description": "ID 4D de l'événement concerné."
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "none",
        "watch",
        "warning",
        "critical"
      ],
      "description": "Niveau de risque météo calculé par l'IA."
    },
    "forecastDate": {
      "type": "string",
      "description": "Date de l'événement analysé – format ISO 8601 YYYY-MM-DD."
    },
    "weatherSummary": {
      "type": "string",
      "description": "Résumé lisible des conditions météo prévues (1-2 phrases)."
    },
    "explanation": {
      "type": "string",
      "description": "Analyse détaillée comparant le weather setup prévu de l'événement (conditions + température planifiées) avec les prévisions météo réelles. Explique l'adéquation ou l'inadéquation des services actuels, justifie chaque action proposée, et indique si des services existants pourraient être retirés ou remplacés. 3-5 phrases."
    },
    "weatherData": {
      "anyOf": [
        {
          "type": "object",
          "description": "Données brutes Open-Meteo résumées.",
          "required": [
            "maxTemperature",
            "minTemperature",
            "precipitationMm",
            "windSpeedKmh",
            "weatherCode",
            "weatherDescription"
          ],
          "additionalProperties": false,
          "properties": {
            "maxTemperature": {
              "type": "number"
            },
            "minTemperature": {
              "type": "number"
            },
            "precipitationMm": {
              "type": "number"
            },
            "windSpeedKmh": {
              "type": "number"
            },
            "weatherCode": {
              "type": "integer"
            },
            "weatherDescription": {
              "type": "string"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "affectedServices": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Services de l'événement potentiellement impactés."
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "actionType",
          "label",
          "priority",
          "description",
          "deadlineToDecide",
          "estimatedExtraCost",
          "suggestedServices",
          "hiddenPrompt"
        ],
        "additionalProperties": false,
        "properties": {
          "actionType": {
            "type": "string",
            "enum": [
              "add_services",
              "replace_services",
              "switch_venue",
              "notify_client"
            ],
            "description": "Type d'action concrète: add_services (ajouter des prestations), replace_services (remplacer des prestations), switch_venue (basculer indoor/outdoor), notify_client (envoyer un message au client)."
          },
          "label": {
            "type": "string",
            "description": "Libellé court de l'action."
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Description détaillée de l'action."
          },
          "priority": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "deadlineToDecide": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Date limite YYYY-MM-DD pour prendre cette décision, ou null."
          },
          "estimatedExtraCost": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Surcoût estimé en euros, ou null."
          },
          "suggestedServices": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "null"
              }
            ],
            "description": "Prestations du catalogue à ajouter, ou null."
          },
          "hiddenPrompt": {
            "type": "string",
            "description": "Prompt caché décrivant précisément ce que l'action doit faire : services de contingence à rechercher, quantités, contraintes météo. Sera envoyé à l'IA lors de l'exécution."
          }
        }
      }
    },
    "draftClientMessage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Brouillon de message client généré par l'IA."
    }
  }
}
